---
import type { Product } from '../content/defaults';

interface Props {
  product: Product;
  class?: string;
  [key: string]: unknown;
}

const { product, class: className, ...rest } = Astro.props;
---

<article
  {...rest}
  class:list={['group relative aspect-[3/4] overflow-hidden bg-ink', className]}
>
  <img
    src={product.image}
    alt={product.imageAlt}
    class="absolute inset-0 h-full w-full scale-105 object-cover blur-[2px] brightness-[0.62] transition-[filter,transform] duration-500 group-hover:scale-100 group-hover:blur-0 group-hover:brightness-90 motion-reduce:transition-none"
    loading="lazy"
    width="768"
    height="432"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/45 to-ink/10" aria-hidden="true"></div>

  {
    product.badge && (
      <span class="absolute top-4 left-4 border border-white/35 bg-ink/40 px-3 py-1 font-mono text-[0.66rem] tracking-[0.12em] text-white uppercase backdrop-blur-sm">
        {product.badge}
      </span>
    )
  }

  <div class="relative flex h-full flex-col justify-end p-6">
    <h3 class="text-xl leading-tight font-semibold text-white">{product.name}</h3>
    <p class="mt-2 max-w-xs text-[0.92rem] leading-relaxed text-white/80">{product.description}</p>
    <a
      href="/kontakt"
      class="mt-4 inline-flex w-fit items-center gap-2 text-[0.9rem] font-semibold text-white"
    >
      Pošaljite upit
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
        <path
          d="M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</article>
