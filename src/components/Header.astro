---
import LogoMark from './LogoMark.astro';

interface Props {
  /** 'overlay' floats transparent over a dark hero and solidifies on scroll. */
  variant?: 'default' | 'overlay';
}

const { variant = 'default' } = Astro.props;
const overlay = variant === 'overlay';

const nav = [
  { label: 'Naslovnica', href: '/' },
  { label: 'Usluge', href: '/usluge' },
  { label: 'O nama', href: '/o-nama' },
  { label: 'Kontakt', href: '/kontakt' },
];
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  id="site-header"
  data-overlay={overlay ? 'true' : undefined}
  class:list={[
    'z-50 w-full transition-colors duration-300',
    overlay
      ? 'fixed top-0 left-0 border-b border-white/10 bg-ink/40 text-white backdrop-blur-lg'
      : 'sticky top-0 border-b border-line bg-porcelain text-ink',
  ]}
>
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-5 md:h-[72px] md:px-8">
    <a href="/" class="flex items-center gap-3" aria-label="Electrical Installations d.o.o. - naslovnica">
      <LogoMark class="h-8" />
      <span class="flex flex-col leading-none">
        <span class="text-[0.72rem] font-bold tracking-[0.16em] text-signal sm:text-[0.82rem] sm:tracking-[0.18em]">
          ELECTRICAL
        </span>
        <span class:list={['mt-0.5 text-[0.6rem] font-medium tracking-[0.2em] sm:text-[0.68rem] sm:tracking-[0.30em]', overlay ? 'text-white/85' : 'text-ink/85']}>
          INSTALLATIONS
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-0 md:flex" aria-label="Glavna navigacija">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'border-l px-5 py-2.5 text-[0.92rem] font-medium transition-colors',
              overlay
                ? ['border-white/15', isActive(item.href) ? 'text-white' : 'text-white/70 hover:text-white']
                : ['border-line', isActive(item.href) ? 'text-ink' : 'text-slate hover:text-ink'],
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/kontakt"
        class="group ml-5 flex items-center gap-2.5 bg-signal px-5 py-2.5 text-[0.92rem] font-semibold text-white transition-colors hover:bg-signal-deep"
      >
        Zatražite ponudu
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
          <path d="M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </nav>

    <button
      id="menu-toggle"
      type="button"
      class:list={[
        'flex h-11 w-11 items-center justify-center border md:hidden',
        overlay ? 'border-white/30 text-white' : 'border-line text-ink',
      ]}
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Otvori izbornik"
    >
      <svg id="icon-open" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M2 5.5h18M2 11h18M2 16.5h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" class="hidden">
        <path d="M4 4l14 14M18 4L4 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class:list={[
      'grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out md:hidden',
      overlay ? 'bg-ink' : '',
    ]}
  >
    <div class="overflow-hidden">
      <nav
        class:list={['flex flex-col border-t px-5 py-4', overlay ? 'border-line-dark' : 'border-line']}
        aria-label="Mobilna navigacija"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'border-b px-2 py-3.5 text-base font-medium',
                overlay
                  ? ['border-line-dark', isActive(item.href) ? 'text-white' : 'text-mist']
                  : ['border-line', isActive(item.href) ? 'text-ink' : 'text-slate'],
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <a href="/kontakt" class="mt-4 bg-signal px-4 py-3.5 text-center text-base font-semibold text-white">
          Zatražite ponudu
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Otvori izbornik' : 'Zatvori izbornik');
    menu?.classList.toggle('grid-rows-[1fr]', !open);
    menu?.classList.toggle('grid-rows-[0fr]', open);
    iconOpen?.classList.toggle('hidden', !open);
    iconClose?.classList.toggle('hidden', open);
  });

  // Overlay header: transparent over the hero, solid ink once scrolled past
  // the top. IntersectionObserver on a sentinel is robust regardless of
  // smooth-scroll libraries hijacking the scroll event.
  const header = document.getElementById('site-header');
  if (header?.dataset.overlay === 'true') {
    const sentinel = document.createElement('div');
    sentinel.setAttribute('aria-hidden', 'true');
    sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:56px;pointer-events:none;';
    document.body.prepend(sentinel);
    new IntersectionObserver(
      ([entry]) => header.classList.toggle('is-solid', !entry.isIntersecting),
      { threshold: 0 }
    ).observe(sentinel);
  }
</script>
