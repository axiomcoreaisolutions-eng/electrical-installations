---
import Button from './Button.astro';
import type { contactCta } from '../content/defaults';

interface Props {
  content: typeof contactCta;
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden bg-ink" aria-label="Poziv na kontakt">
  <!-- Interactive schematic cross-grid: faint by default, lights up and scales
       toward the cursor. Built + driven in motion.ts (desktop, motion-OK only). -->
  <div
    data-cross-grid
    data-cross-interactive
    class="pointer-events-none absolute inset-0 hidden md:block"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-5 py-24 md:px-8 md:py-36" data-reveal>
    <div class="max-w-3xl">
      <h2 data-reveal-words class="display text-(length:--text-display-lg) text-white">{content.headline}</h2>
      <p class="mt-5 text-lg leading-relaxed text-mist">{content.supporting}</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href={content.primaryCta.href} size="lg">{content.primaryCta.label}</Button>
        <Button href={content.secondaryCta.href} variant="ghost-dark" size="lg">
          {content.secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>
