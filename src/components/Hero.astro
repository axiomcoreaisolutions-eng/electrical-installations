---
import type { heroContent } from '../content/defaults';
import { getSiteSettings, getCategories } from '../lib/content';

interface Props {
  hero: typeof heroContent;
}

const { hero } = Astro.props;
const settings = await getSiteSettings();
const categories = await getCategories();
const arrow = 'M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75';
---

<section class="relative min-h-[100svh] overflow-hidden bg-ink text-white" aria-label="Uvod">
  <!-- Full-bleed media -->
  <div id="hero-media" class="absolute inset-x-0 -top-[6%] -bottom-[6%] will-change-transform" aria-hidden="true">
    <img
      src="/media/hero-poster.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <video
      id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"
      muted
      loop
      playsinline
      autoplay
      preload="none"
      poster="/media/hero-poster.jpg"
      data-src="/media/hero.mp4"
      tabindex="-1"
    ></video>
  </div>

  <!-- Atmosphere: gradient wash + steel aurora + film grain -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="hero-aurora absolute inset-0 opacity-60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/55 to-ink/70"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-ink/85 via-ink/30 to-transparent"></div>
    <div class="hero-grain absolute inset-0"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto flex min-h-[100svh] max-w-[1400px] flex-col px-5 pt-24 pb-0 md:px-8 md:pt-28">
    <!-- Instrument label row -->
    <div
      data-hero-seq
      class="flex flex-wrap items-baseline justify-between gap-3 border-b border-white/15 pb-4 font-mono text-[0.72rem] font-medium tracking-[0.16em] text-mist uppercase"
    >
      <span>Tehnički sustavi - Zagreb</span>
      <span>Od {settings.foundedYear}.</span>
    </div>

    <div class="flex flex-1 flex-col justify-center py-12">
      <p data-hero-seq class="mb-6 flex items-center gap-3 font-mono text-[0.75rem] tracking-[0.18em] text-mist uppercase">
        <span class="inline-block h-px w-8 bg-signal"></span>
        Jedan partner, jedna odgovornost
      </p>

      <h1 data-split class="display max-w-4xl text-(length:--text-display-xl) text-white">
        {hero.headline}
      </h1>

      <p data-hero-seq class="mt-7 max-w-2xl text-lg leading-relaxed text-mist md:text-xl">
        {hero.subheadline}
      </p>

      <div data-hero-seq class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href={hero.primaryCta.href}
          data-magnetic
          class="group inline-flex items-center gap-2.5 bg-signal px-6 py-3.5 text-base font-semibold text-white transition-colors hover:bg-signal-deep"
        >
          <span class="btn-swap"><span class="btn-swap_inner"><span>{hero.primaryCta.label}</span><span aria-hidden="true">{hero.primaryCta.label}</span></span></span>
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
            <path d={arrow} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href={hero.secondaryCta.href}
          class="group inline-flex items-center gap-2.5 border border-white/30 px-6 py-3.5 text-base font-semibold text-white transition-colors hover:border-white/70 hover:bg-white/5"
        >
          <span class="btn-swap"><span class="btn-swap_inner"><span>{hero.secondaryCta.label}</span><span aria-hidden="true">{hero.secondaryCta.label}</span></span></span>
        </a>
      </div>
    </div>

    <!-- Service marquee (bottom strip) -->
    <div class="relative overflow-hidden border-t border-white/15 py-4" aria-hidden="true">
      <div class="marquee-track flex w-max items-center gap-8" data-marquee>
        {
          [0, 1].map(() =>
            categories.map((cat) => (
              <span class="flex items-center gap-8 font-mono text-[0.75rem] tracking-[0.14em] whitespace-nowrap text-mist uppercase">
                {cat.title}
                <span class="inline-block h-1 w-1 rounded-full bg-signal"></span>
              </span>
            ))
          )
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Video loads only on desktop, motion-OK, no data-saver - otherwise poster.
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const wantsMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
  const isDesktop = window.matchMedia('(min-width: 768px)').matches;
  const connection = (navigator as { connection?: { saveData?: boolean } }).connection;

  if (video && wantsMotion && isDesktop && connection?.saveData !== true) {
    const source = document.createElement('source');
    source.src = video.dataset.src ?? '';
    source.type = 'video/mp4';
    video.append(source);
    video.load();
    video.addEventListener('playing', () => video.classList.remove('opacity-0'), { once: true });
    video.play().catch(() => {});
  }
</script>
