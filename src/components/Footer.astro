---
import LogoMark from './LogoMark.astro';
import { getSiteSettings, getCategories } from '../lib/content';

const settings = await getSiteSettings();
const categories = await getCategories();
const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <div class="mx-auto max-w-[1400px] px-5 md:px-8">
    <!-- Lead: brand statement + prominent contact -->
    <div class="grid gap-12 border-b border-line-dark py-16 md:grid-cols-[1.2fr_1fr] md:items-end md:py-24">
      <div>
        <a href="/" class="flex items-center gap-3 text-white" aria-label="Electrical Installations d.o.o. - naslovnica">
          <LogoMark class="h-9" />
          <span class="flex flex-col leading-none">
            <span class="text-[0.85rem] font-bold tracking-[0.18em] text-signal">ELECTRICAL</span>
            <span class="mt-0.5 text-[0.7rem] font-medium tracking-[0.30em] text-white/85">INSTALLATIONS</span>
          </span>
        </a>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-mist">
          {settings.positioningLine} Jedan partner za više ključnih sustava objekta.
        </p>
      </div>

      <div class="md:justify-self-end md:text-right">
        <p class="eyebrow-chip is-dark">
          <span class="eyebrow-chip_dot" aria-hidden="true"></span>
          Kontakt
        </p>
        <a
          href={`tel:${settings.phoneHref}`}
          class="mt-4 block text-2xl font-semibold text-white transition-colors hover:text-mist"
        >
          {settings.phone}
        </a>
        <a href={`mailto:${settings.email}`} class="mt-1 block text-lg text-mist transition-colors hover:text-white">
          {settings.email}
        </a>
        <p class="mt-3 font-mono text-[0.8rem] leading-relaxed text-white/55">{settings.address}</p>
      </div>
    </div>

    <!-- Nav columns -->
    <div class="grid gap-10 py-14 sm:grid-cols-3">
      <nav aria-label="Usluge">
        <p class="eyebrow text-white/50">Usluge</p>
        <ul class="mt-5 space-y-2.5">
          {
            categories.map((cat) => (
              <li>
                <a href={`/usluge/${cat.slug}`} class="text-[0.92rem] leading-snug text-mist transition-colors hover:text-white">
                  {cat.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Stranice">
        <p class="eyebrow text-white/50">Stranice</p>
        <ul class="mt-5 space-y-2.5">
          <li><a href="/" class="text-[0.92rem] text-mist transition-colors hover:text-white">Naslovnica</a></li>
          <li><a href="/usluge" class="text-[0.92rem] text-mist transition-colors hover:text-white">Usluge</a></li>
          <li><a href="/o-nama" class="text-[0.92rem] text-mist transition-colors hover:text-white">O nama</a></li>
          <li><a href="/kontakt" class="text-[0.92rem] text-mist transition-colors hover:text-white">Kontakt</a></li>
        </ul>
      </nav>

      <nav aria-label="Pravno">
        <p class="eyebrow text-white/50">Pravno</p>
        <ul class="mt-5 space-y-2.5">
          <li>
            <a href="/politika-privatnosti" class="text-[0.92rem] text-mist transition-colors hover:text-white">
              Politika privatnosti
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col gap-3 border-t border-line-dark py-6 text-[0.8rem] text-white/50 md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} {settings.companyName} Sva prava pridržana.</p>
      <div class="flex items-center gap-5">
        <p class="font-mono">Zagreb, Hrvatska</p>
        <button
          type="button"
          data-scroll-top
          aria-label="Natrag na vrh"
          class="group flex h-10 w-10 items-center justify-center border border-white/25 text-white transition-colors hover:border-white/70"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:-translate-y-0.5">
            <path d="M8 13V3m0 0L3.5 7.5M8 3l4.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.querySelector('[data-scroll-top]')?.addEventListener('click', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const lenis = (window as unknown as { lenis?: { scrollTo: (t: number, o?: object) => void } }).lenis;
    if (lenis) lenis.scrollTo(0, { immediate: reduce });
    else window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
  });
</script>
