---
import type { ServiceCategory } from '../content/defaults';
import { homeFeatures } from '../content/defaults';

interface Props {
  category: ServiceCategory;
  index: number;
}

const { category, index } = Astro.props;
const feature = homeFeatures[category.slug];
const reversed = index % 2 === 1;
const num = String(index + 1).padStart(2, '0');
const arrow = 'M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75';
// Mosaic reveal tiles (8×5 grid); count kept low for performance.
const tiles = Array.from({ length: 40 });
---

<a
  href={`/usluge/${category.slug}`}
  class="group grid items-center gap-8 border-t border-line py-14 md:gap-14 md:py-20 lg:grid-cols-2"
>
  <!-- Media -->
  <div
    class:list={[
      'relative aspect-[4/3] overflow-hidden bg-ink',
      reversed ? 'lg:order-2' : 'lg:order-1',
    ]}
    data-parallax
  >
    <img
      src={category.image}
      alt={category.imageAlt}
      class="absolute inset-0 h-full w-full scale-105 object-cover transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
      width="1200"
      height="900"
    />
    <div class="pointer-events-none absolute inset-0 grid grid-cols-8 grid-rows-5" data-mosaic aria-hidden="true">
      {tiles.map(() => <span class="bg-white"></span>)}
    </div>
  </div>

  <!-- Content -->
  <div class:list={[reversed ? 'lg:order-1 lg:pr-10' : 'lg:order-2 lg:pl-10']}>
    <p class="font-mono text-[0.8rem] font-medium tracking-[0.16em] text-signal">{num}</p>
    <h3 class="display mt-4 text-(length:--text-display-md) text-ink">{category.title}</h3>
    <p class="mt-4 max-w-md text-lg leading-relaxed text-slate">{feature?.line ?? category.shortDescription}</p>

    {
      feature && (
        <dl class="mt-8 max-w-md">
          {feature.specs.map((s) => (
            <div class="grid grid-cols-[7rem_1fr] gap-4 border-t border-line py-3">
              <dt class="font-mono text-[0.68rem] tracking-[0.12em] text-slate uppercase">{s.k}</dt>
              <dd class="text-[0.95rem] font-medium text-ink">{s.v}</dd>
            </div>
          ))}
        </dl>
      )
    }

    <span class="mt-8 inline-flex items-center gap-2 text-[0.95rem] font-semibold text-ink">
      <span class="btn-swap"><span class="btn-swap_inner"><span>Saznajte više</span><span aria-hidden="true">Saznajte više</span></span></span>
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
        <path d={arrow} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>
