---
import type { ServiceCategory } from '../content/defaults';
import { homeFeatures } from '../content/defaults';

interface Props {
  category: ServiceCategory;
  index: number;
}

const { category, index } = Astro.props;
const feature = homeFeatures[category.slug];
const num = String(index + 1).padStart(2, '0');
const arrow = 'M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75';
// Mosaic reveal tiles (8×5 grid); dark so the image emerges from black.
const tiles = Array.from({ length: 40 });
---

<a
  href={`/usluge/${category.slug}`}
  class="group relative block aspect-[4/3] overflow-hidden bg-ink sm:aspect-[3/4]"
>
  <img
    src={category.image}
    alt={category.imageAlt}
    class="absolute inset-0 h-full w-full scale-105 object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.12]"
    loading="lazy"
    width="900"
    height="1100"
  />

  <!-- Mosaic reveal: dark tiles cover the image, then dissolve on scroll-in -->
  <div class="pointer-events-none absolute inset-0 grid grid-cols-8 grid-rows-5" data-mosaic aria-hidden="true">
    {tiles.map(() => <span class="bg-ink"></span>)}
  </div>

  <!-- Legibility scrim -->
  <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/45 to-ink/5" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-ink/10 transition-colors duration-500 group-hover:bg-transparent" aria-hidden="true"></div>

  <!-- Overlaid text -->
  <div class="relative flex h-full flex-col justify-between p-6 md:p-8">
    <p class="font-mono text-[0.78rem] font-medium tracking-[0.16em] text-white/75">{num}</p>
    <div>
      <h3 class="display text-(length:--text-display-md) text-white">{category.title}</h3>
      <p class="mt-3 max-w-sm text-[1.02rem] leading-relaxed text-white/85">
        {feature?.line ?? category.shortDescription}
      </p>
      <span class="mt-6 inline-flex items-center gap-2 text-[0.95rem] font-semibold text-white">
        <span class="btn-swap"><span class="btn-swap_inner"><span>Saznajte više</span><span aria-hidden="true">Saznajte više</span></span></span>
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
          <path d={arrow} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>
  </div>
</a>
