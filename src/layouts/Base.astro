---
import '@fontsource-variable/archivo/standard.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LogoMark from '../components/LogoMark.astro';
import { getSiteSettings } from '../lib/content';

interface Props {
  title: string;
  description: string;
  /** 'overlay' floats the header transparent over the dark hero (homepage). */
  headerVariant?: 'default' | 'overlay';
}

const { title, description, headerVariant = 'default' } = Astro.props;
const settings = await getSiteSettings();
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: settings.companyName,
  description: settings.positioningLine,
  url: Astro.site?.toString(),
  telephone: settings.phoneHref,
  email: settings.email,
  foundingDate: String(settings.foundedYear),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Krapanjska ulica 12',
    postalCode: '10000',
    addressLocality: 'Zagreb',
    addressCountry: 'HR',
  },
};
---

<!doctype html>
<html lang="hr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={settings.companyName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/media/hero-poster.jpg', Astro.site)} />
    <meta property="og:locale" content="hr_HR" />
    <meta name="twitter:card" content="summary_large_image" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
    <!-- Preloader gate: set before paint so content never flashes first.
         Skipped entirely under reduced-motion; a failsafe unlocks after 2.6s
         so a stalled load can never trap the page. -->
    <script is:inline>
      (function () {
        try {
          if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('is-loading');
            setTimeout(function () {
              document.documentElement.classList.remove('is-loading');
            }, 2600);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-porcelain text-ink antialiased">
    <div id="preloader" class="preloader" aria-hidden="true">
      <div class="preloader_inner text-white">
        <LogoMark class="preloader_mark h-11" interactive={false} />
        <span class="preloader_word">Electrical Installations</span>
      </div>
      <span class="preloader_bar"><span></span></span>
    </div>
    <a
      href="#glavni-sadrzaj"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-lg focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >
      Preskoči na sadržaj
    </a>
    <Header variant={headerVariant} />
    <main id="glavni-sadrzaj">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/motion.ts"></script>
    <script>
      // Reveal: lift the preloader once the page is ready. Guarded so it only
      // runs when the gate is active (i.e. not under reduced-motion).
      const pre = document.getElementById('preloader');
      if (pre && document.documentElement.classList.contains('is-loading')) {
        const done = () => {
          pre.classList.add('is-done');
          document.documentElement.classList.remove('is-loading');
          pre.addEventListener('transitionend', () => pre.remove(), { once: true });
        };
        if (document.readyState === 'complete') setTimeout(done, 450);
        else window.addEventListener('load', () => setTimeout(done, 350));
      }
    </script>
  </body>
</html>
