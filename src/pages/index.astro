---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ContactForm from '../components/ContactForm.astro';
import Button from '../components/Button.astro';
import { getHomepage, getCategories, getContactPage, seo } from '../lib/content';

const homepage = await getHomepage();
const categories = await getCategories();
const contact = await getContactPage();
const featured = categories.filter((c) => c.featured);
const rest = categories.filter((c) => !c.featured);
---

<Base title={seo.homeTitle} description={seo.homeDescription}>
  <Hero hero={homepage.hero} />

  <!-- Ambient ticker: decorative system inventory strip -->
  <div class="overflow-hidden bg-porcelain py-5" aria-hidden="true">
    <div class="ticker-track flex w-max items-center gap-10 pl-5" data-ticker>
      {
        [0, 1].map(() =>
          categories.map((cat) => (
            <span class="flex items-center gap-10 font-mono text-[0.72rem] tracking-[0.16em] whitespace-nowrap text-slate uppercase">
              {cat.title}
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal"></span>
            </span>
          ))
        )
      }
    </div>
  </div>

  <!-- 2 — Umbrella categories -->
  <section class="bg-porcelain" aria-labelledby="usluge-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <SectionHead
        eyebrow="Sustavi"
        headline={homepage.categoriesSection.headline}
        supporting={homepage.categoriesSection.supporting}
      />
      <span id="usluge-naslov" class="sr-only">{homepage.categoriesSection.headline}</span>
      <div class="mt-12 grid gap-4 sm:grid-cols-6">
        {featured.map((cat) => <CategoryCard category={cat} class="sm:col-span-6" data-reveal-card />)}
        {
          rest.map((cat, i) => (
            <CategoryCard
              category={cat}
              class={`sm:col-span-3 ${i < 3 ? 'lg:col-span-2' : ''}`}
              data-reveal-card
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3 — Why this matters -->
  <section class="bg-ink" aria-labelledby="zasto-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <SectionHead
        eyebrow="Zašto je važno"
        headline={homepage.whySection.headline}
        supporting={homepage.whySection.supporting}
        dark
      />
      <span id="zasto-naslov" class="sr-only">{homepage.whySection.headline}</span>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          homepage.whySection.consequences.map((item) => (
            <div class="rounded-xl border border-line-dark bg-ink-2 p-6" data-reveal-card>
              <h3 class="text-lg font-semibold text-white">{item.title}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-mist">{item.text}</p>
            </div>
          ))
        }
      </div>
      <div class="schematic-rule schematic-rule--dark mt-12" aria-hidden="true"></div>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-white" data-reveal>
        {homepage.whySection.closing}
      </p>
    </div>
  </section>

  <!-- 4 — Process -->
  <section class="bg-white" aria-labelledby="proces-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <SectionHead eyebrow="Proces" headline={homepage.processSection.headline} />
      <span id="proces-naslov" class="sr-only">{homepage.processSection.headline}</span>
      <div class="relative mt-12 h-px bg-line" aria-hidden="true">
        <div class="absolute inset-0 origin-left bg-signal" data-draw-line></div>
      </div>
      <ol class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {
          homepage.processSection.steps.map((step, i) => (
            <li class="relative rounded-xl border border-line bg-porcelain p-6" data-reveal-card>
              <p class="font-mono text-[0.8rem] font-medium tracking-[0.14em] text-signal">
                {String(i + 1).padStart(2, '0')}
              </p>
              <h3 class="mt-3 text-[1.05rem] leading-snug font-semibold text-ink">{step.title}</h3>
              <p class="mt-2 text-[0.9rem] leading-relaxed text-slate">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 5 — Featured category deep dive -->
  <section class="bg-porcelain" aria-labelledby="vodovod-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
        <div data-reveal>
          <p class="eyebrow flex items-center gap-3 text-slate">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
            Vodovod i kanalizacija
          </p>
          <h2 id="vodovod-naslov" class="display mt-4 text-(length:--text-display-lg) text-ink">
            {homepage.deepDiveSection.headline}
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate">{homepage.deepDiveSection.supporting}</p>
          <ul class="mt-7 grid gap-2.5 sm:grid-cols-2">
            {
              homepage.deepDiveSection.problems.map((problem) => (
                <li class="flex items-baseline gap-2.5 text-[0.95rem] leading-snug text-ink">
                  <span class="h-1.5 w-1.5 shrink-0 translate-y-[-1px] rounded-full bg-steel" aria-hidden="true" />
                  {problem}
                </li>
              ))
            }
          </ul>
          <p class="mt-7 max-w-xl text-[0.98rem] leading-relaxed text-slate">
            {homepage.deepDiveSection.closing}
          </p>
          <Button href={homepage.deepDiveSection.ctaHref} class="mt-8">
            {homepage.deepDiveSection.ctaLabel}
          </Button>
        </div>
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-ink" data-reveal data-parallax>
          <img
            src="/images/vodovod.jpg"
            alt="Cijevi i ventili u strojarnici vodovodnog sustava"
            class="absolute inset-0 h-full w-full scale-110 object-cover opacity-90"
            loading="lazy"
            width="1200"
            height="900"
          />
          <p
            class="absolute bottom-0 left-0 m-4 rounded-md bg-ink/70 px-3 py-1.5 font-mono text-[0.7rem] tracking-[0.14em] text-mist backdrop-blur-sm"
          >
            DETEKCIJA — VODOVODNI SUSTAVI
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6 — Trust / way of working -->
  <section class="bg-white" aria-labelledby="povjerenje-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <SectionHead eyebrow="Način rada" headline={homepage.trustSection.headline} />
      <span id="povjerenje-naslov" class="sr-only">{homepage.trustSection.headline}</span>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          homepage.trustSection.cards.map((card) => (
            <div class="rounded-xl border border-line bg-porcelain p-6" data-reveal-card>
              <div class="h-px w-8 bg-signal" aria-hidden="true" />
              <h3 class="mt-4 text-lg font-semibold text-ink">{card.title}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-slate">{card.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7 — About -->
  <section class="bg-porcelain" aria-labelledby="onama-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.3fr] lg:gap-16" data-reveal>
        <div>
          <p class="eyebrow flex items-center gap-3 text-slate">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
            O nama
          </p>
          <h2 id="onama-naslov" class="display mt-4 text-(length:--text-display-lg) text-ink">
            {homepage.aboutSection.headline}
          </h2>
        </div>
        <div>
          {
            homepage.aboutSection.paragraphs.map((p) => (
              <p class="mt-4 text-[1.02rem] leading-relaxed text-slate first:mt-1">{p}</p>
            ))
          }
          <a
            href="/o-nama"
            class="mt-6 inline-flex items-center gap-2 text-[0.95rem] font-semibold text-ink hover:text-signal-deep"
          >
            Više o tvrtki
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path
                d="M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8 — Contact CTA -->
  <CtaBanner content={homepage.contactCta} />

  <!-- 9 — Contact form -->
  <section class="bg-white" aria-labelledby="upit-naslov">
    <div class="mx-auto max-w-[1200px] px-5 py-20 md:px-8 md:py-28">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
        <div data-reveal>
          <p class="eyebrow flex items-center gap-3 text-slate">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
            Kontakt
          </p>
          <h2 id="upit-naslov" class="display mt-4 text-(length:--text-display-lg) text-ink">
            {contact.formTitle}
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate">{contact.supporting}</p>
        </div>
        <div data-reveal>
          <ContactForm content={contact} idPrefix="upit-home" />
        </div>
      </div>
    </div>
  </section>
</Base>
