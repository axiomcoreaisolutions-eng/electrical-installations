---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ContactForm from '../components/ContactForm.astro';
import Button from '../components/Button.astro';
import Carousel from '../components/Carousel.astro';
import ProductCard from '../components/ProductCard.astro';
import FeatureRow from '../components/FeatureRow.astro';
import { getHomepage, getCategories, getContactPage, seo } from '../lib/content';
import { products, homeStatement } from '../content/defaults';

const homepage = await getHomepage();
const categories = await getCategories();
const contact = await getContactPage();
const arrow = 'M2.5 7.5h10m0 0L8.75 3.75M12.5 7.5l-3.75 3.75';
---

<Base title={seo.homeTitle} description={seo.homeDescription} headerVariant="overlay">
  <Hero hero={homepage.hero} />

  <!-- Statement: one editorial line, word-by-word reveal -->
  <section class="bg-white" aria-labelledby="tko-smo-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.7fr] lg:gap-16" data-reveal>
        <p class="eyebrow-chip self-start">
          <span class="eyebrow-chip_dot" aria-hidden="true"></span>
          {homeStatement.eyebrow}
        </p>
        <div>
          <h2 data-reveal-words id="tko-smo-naslov" class="display text-(length:--text-display-lg) text-ink">
            {homeStatement.text}
          </h2>
          <a
            href={homeStatement.href}
            class="group mt-8 inline-flex items-center gap-2 text-[0.95rem] font-semibold text-ink hover:text-signal-deep"
          >
            <span class="btn-swap"><span class="btn-swap_inner"><span>{homeStatement.linkLabel}</span><span aria-hidden="true">{homeStatement.linkLabel}</span></span></span>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
              <path d={arrow} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature rows: the six systems, image-forward with mosaic reveal -->
  <section class="bg-white" aria-labelledby="sustavi-naslov">
    <div class="mx-auto max-w-[1400px] px-5 pb-24 md:px-8 md:pb-36">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow-chip">
          <span class="eyebrow-chip_dot" aria-hidden="true"></span>
          Sustavi
        </p>
        <h2 data-reveal-words id="sustavi-naslov" class="display mt-6 text-(length:--text-display-lg) text-ink">
          {homepage.categoriesSection.headline}
        </h2>
      </div>
      <div class="mt-10">
        {categories.map((cat, i) => <FeatureRow category={cat} index={i} />)}
        <div class="border-t border-line"></div>
      </div>
    </div>
  </section>

  <!-- Process (compact) -->
  <section class="bg-porcelain" aria-labelledby="proces-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <SectionHead eyebrow="Proces" headline={homepage.processSection.headline} />
      <span id="proces-naslov" class="sr-only">{homepage.processSection.headline}</span>
      <div class="relative mt-12 h-px bg-line" aria-hidden="true">
        <div class="absolute inset-0 origin-left bg-signal" data-draw-line></div>
      </div>
      <ol class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {
          homepage.processSection.steps.map((step, i) => (
            <li class="border border-line bg-white p-6" data-reveal-card>
              <p class="font-mono text-[0.8rem] font-medium tracking-[0.14em] text-signal">
                {String(i + 1).padStart(2, '0')}
              </p>
              <h3 class="mt-3 text-[1.02rem] leading-snug font-semibold text-ink">{step.title}</h3>
              <p class="mt-2 text-[0.88rem] leading-relaxed text-slate">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Why it matters (one line) -->
  <section class="bg-white" aria-labelledby="zasto-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <div class="max-w-4xl" data-reveal>
        <p class="eyebrow-chip">
          <span class="eyebrow-chip_dot" aria-hidden="true"></span>
          Zašto je važno
        </p>
        <h2 data-reveal-words id="zasto-naslov" class="display mt-6 text-(length:--text-display-lg) text-ink">
          {homepage.whySection.headline}
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate">{homepage.whySection.closing}</p>
      </div>
    </div>
  </section>

  <!-- Way of working: three image cards -->
  <section class="bg-porcelain" aria-labelledby="povjerenje-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <SectionHead eyebrow="Način rada" headline={homepage.trustSection.headline} />
      <span id="povjerenje-naslov" class="sr-only">{homepage.trustSection.headline}</span>
      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {
          homepage.trustSection.cards.slice(0, 3).map((card, i) => (
            <div class="overflow-hidden border border-line bg-white" data-reveal-card>
              <div class="relative aspect-[3/2] overflow-hidden bg-ink" data-parallax>
                <img
                  src={['/images/vodovod.jpg', '/images/legacy/o-nama.jpg', '/images/elektro.jpg'][i]}
                  alt=""
                  class="absolute inset-0 h-full w-full scale-105 object-cover"
                  loading="lazy"
                  width="640"
                  height="427"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-ink">{card.title}</h3>
                <p class="mt-2 text-[0.92rem] leading-relaxed text-slate">{card.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Products: Stekerr EV chargers (image cards + carousel) -->
  <section class="bg-ink" aria-labelledby="uredaji-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <div class="flex flex-wrap items-end justify-between gap-6" data-reveal>
        <div class="max-w-2xl">
          <p class="eyebrow-chip is-dark">
            <span class="eyebrow-chip_dot" aria-hidden="true"></span>
            Uređaji
          </p>
          <h2 data-reveal-words id="uredaji-naslov" class="display mt-6 text-(length:--text-display-lg) text-white">
            Stekerr punionice električnih vozila
          </h2>
        </div>
        <Button href="/usluge/ev-punionice/uredaji" variant="ghost-dark" class="shrink-0">Svi uređaji</Button>
      </div>

      <Carousel label="Stekerr uređaji" slideClass="w-[74vw] sm:w-[300px]" dark class="mt-12">
        {products.map((product) => <ProductCard product={product} />)}
      </Carousel>
    </div>
  </section>

  <!-- Contact CTA -->
  <CtaBanner content={homepage.contactCta} />

  <!-- Contact form -->
  <section class="bg-white" aria-labelledby="upit-naslov">
    <div class="mx-auto max-w-[1400px] px-5 py-24 md:px-8 md:py-36">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
        <div data-reveal>
          <p class="eyebrow-chip">
            <span class="eyebrow-chip_dot" aria-hidden="true"></span>
            Kontakt
          </p>
          <h2 data-reveal-words id="upit-naslov" class="display mt-6 text-(length:--text-display-lg) text-ink">
            {contact.formTitle}
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate">{contact.supporting}</p>
        </div>
        <div data-reveal>
          <ContactForm content={contact} idPrefix="upit-home" />
        </div>
      </div>
    </div>
  </section>
</Base>
