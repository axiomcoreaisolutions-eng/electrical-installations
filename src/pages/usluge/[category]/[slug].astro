---
import Base from '../../../layouts/Base.astro';
import Button from '../../../components/Button.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import { getCategories, getHomepage } from '../../../lib/content';
import type { ServiceCategory, Subservice } from '../../../content/defaults';

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.flatMap((category) =>
    category.subservices.map((subservice) => ({
      params: { category: category.slug, slug: subservice.slug },
      props: { category, subservice },
    }))
  );
}

interface Props {
  category: ServiceCategory;
  subservice: Subservice;
}

const { category, subservice } = Astro.props;
const homepage = await getHomepage();
const siblings = category.subservices.filter((s) => s.slug !== subservice.slug);
---

<Base title={subservice.seoTitle} description={subservice.seoDescription}>
  <section class="border-b border-line bg-porcelain">
    <div class="mx-auto max-w-[1400px] px-5 pt-12 pb-14 md:px-8 md:pt-16 md:pb-20">
      <nav aria-label="Putanja" class="border-b border-line pb-4 font-mono text-[0.75rem] tracking-[0.08em] text-slate uppercase">
        <a href="/usluge" class="transition-colors hover:text-ink">Usluge</a>
        <span aria-hidden="true"> / </span>
        <a
          href={`/usluge/${category.slug}`}
          class="inline-block max-w-[16rem] truncate align-bottom transition-colors hover:text-ink sm:max-w-none"
        >
          {category.title}
        </a>
      </nav>
      <h1 data-split class="display mt-8 max-w-4xl text-(length:--text-display-xl) text-ink">{subservice.title}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate">{subservice.shortDescription}</p>
      <div class="mt-9">
        <Button href="/kontakt" size="lg">Pošaljite upit</Button>
      </div>
    </div>
  </section>

  <section class="bg-porcelain">
    <div class="mx-auto max-w-[1200px] px-5 py-16 md:px-8 md:py-24">
      <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:gap-16">
        <div data-reveal>
          {
            subservice.longDescription.map((p) => (
              <p class="mt-5 text-[1.05rem] leading-relaxed text-ink first:mt-0">{p}</p>
            ))
          }

          {
            subservice.bullets && subservice.bullets.length > 0 && (
              <>
                <h2 class="mt-10 text-xl font-semibold text-ink">Što obuhvaća</h2>
                <ul class="mt-5 grid gap-2.5 sm:grid-cols-2">
                  {subservice.bullets.map((bullet) => (
                    <li class="flex items-baseline gap-2.5 text-[0.95rem] leading-snug text-ink">
                      <span class="h-1.5 w-1.5 shrink-0 translate-y-[-1px] rounded-full bg-steel" aria-hidden="true" />
                      {bullet}
                    </li>
                  ))}
                </ul>
              </>
            )
          }

          {
            subservice.steps && subservice.steps.length > 0 && (
              <>
                <h2 class="mt-10 text-xl font-semibold text-ink">Kako izgleda proces</h2>
                <ol class="mt-5 space-y-0">
                  {subservice.steps.map((step, i) => (
                    <li class="grid grid-cols-[3rem_1fr] gap-4 border-t border-line py-5">
                      <span class="font-mono text-[0.85rem] font-medium tracking-[0.14em] text-signal">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <div>
                        <h3 class="text-[1.05rem] leading-snug font-semibold text-ink">{step.title}</h3>
                        {step.text && <p class="mt-1.5 text-[0.95rem] leading-relaxed text-slate">{step.text}</p>}
                      </div>
                    </li>
                  ))}
                </ol>
              </>
            )
          }

          {
            subservice.images && subservice.images.length > 0 && (
              <div class="mt-10 grid gap-4 sm:grid-cols-2">
                {subservice.images.map((img) => (
                  <div class="relative aspect-[4/3] overflow-hidden bg-ink" data-parallax>
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="absolute inset-0 h-full w-full scale-110 object-cover"
                      loading="lazy"
                      width="800"
                      height="600"
                    />
                  </div>
                ))}
              </div>
            )
          }

          <p class="mt-8 border border-line bg-white p-5 text-[0.95rem] leading-relaxed text-slate">
            Dio kategorije:{' '}
            <a href={`/usluge/${category.slug}`} class="font-semibold text-ink underline decoration-line underline-offset-2 hover:decoration-ink">
              {category.title}
            </a>
          </p>
        </div>
        {
          siblings.length > 0 && (
            <aside data-reveal>
              <p class="eyebrow text-slate">Povezane usluge</p>
              <ul class="mt-4 space-y-2.5">
                {siblings.map((s) => (
                  <li>
                    <a
                      href={`/usluge/${category.slug}/${s.slug}`}
                      class="block rounded-lg border border-line bg-white px-4 py-3 text-[0.95rem] font-medium text-ink transition-colors hover:border-ink"
                    >
                      {s.title}
                    </a>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }
      </div>
    </div>
  </section>

  <CtaBanner content={homepage.contactCta} />
</Base>
