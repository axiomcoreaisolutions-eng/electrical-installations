---
import Base from '../layouts/Base.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { getHomepage, getSiteSettings } from '../lib/content';

const homepage = await getHomepage();
const settings = await getSiteSettings();
---

<Base
  title="O nama | Electrical Installations d.o.o."
  description="Electrical Installations d.o.o., osnovan 2023., partner je za tehničke sustave objekata: vodovod i detekciju kvarova, elektroinstalacije, solar, klimatizaciju, parking i EV punionice."
>
  <section class="border-b border-line bg-porcelain">
    <div class="mx-auto max-w-[1400px] px-5 pt-12 pb-14 md:px-8 md:pt-16 md:pb-20">
      <p class="eyebrow flex items-center gap-3 border-b border-line pb-4 text-slate">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
        O nama
      </p>
      <h1 data-split class="display mt-8 max-w-4xl text-(length:--text-display-xl) text-ink">
        {homepage.aboutSection.headline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate">
        {settings.positioningLine} Jedan partner za više ključnih sustava objekta.
      </p>
    </div>
  </section>

  <section class="bg-porcelain">
    <div class="mx-auto max-w-[1200px] px-5 py-16 md:px-8 md:py-24">
      <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:gap-16">
        <div data-reveal>
          {
            homepage.aboutSection.paragraphs.map((p) => (
              <p class="mt-5 text-[1.05rem] leading-relaxed text-ink first:mt-0">{p}</p>
            ))
          }

          <h2 class="mt-12 text-xl font-semibold text-ink">Način rada</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {
              homepage.trustSection.cards.map((card) => (
                <div class="rounded-xl border border-line bg-white p-5" data-reveal-card>
                  <div class="h-px w-8 bg-signal" aria-hidden="true" />
                  <h3 class="mt-3 text-[1.05rem] font-semibold text-ink">{card.title}</h3>
                  <p class="mt-1.5 text-[0.9rem] leading-relaxed text-slate">{card.text}</p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="space-y-4" data-reveal>
          <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-ink" data-parallax>
            <img
              src="/images/legacy/o-nama.jpg"
              alt="Službeno vozilo tvrtke Electrical Installations"
              class="absolute inset-0 h-full w-full scale-110 object-cover"
              loading="lazy"
              width="1200"
              height="900"
            />
          </div>
          <div class="rounded-xl border border-line bg-white p-6">
            <p class="eyebrow text-slate">Podaci o tvrtki</p>
            <dl class="mt-4 space-y-3 font-mono text-[0.85rem] leading-relaxed">
              <div>
                <dt class="text-slate">Tvrtka</dt>
                <dd class="text-ink">{settings.companyName}</dd>
              </div>
              <div>
                <dt class="text-slate">Osnovana</dt>
                <dd class="text-ink">{settings.foundedYear}.</dd>
              </div>
              <div>
                <dt class="text-slate">Adresa</dt>
                <dd class="text-ink">{settings.address}</dd>
              </div>
              <div>
                <dt class="text-slate">Kontakt</dt>
                <dd class="text-ink">
                  <a href={`tel:${settings.phoneHref}`} class="hover:text-signal-deep">{settings.phone}</a>
                  <br />
                  <a href={`mailto:${settings.email}`} class="hover:text-signal-deep">{settings.email}</a>
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner content={homepage.contactCta} />
</Base>
